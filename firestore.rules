rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user is signed in with a Thapar email
    function isThaparStudent() {
      return isAuthenticated() && request.auth.token.email.endsWith('@thapar.edu');
    }

    // Helper: Check if the user is a designated administrator
    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email in ['umanglik_be25@thapar.edu']; 
    }

    // 1. System Config: Anyone can read (e.g. landing page stats setting), only Admins can write
    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 2. Announcements: Anyone can read, only Admins can write
    match /announcements/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 3. PYQs: Anyone can read, only Admins can write (updates allowed for downloads count)
    match /pyqs/{document} {
      allow read, write: if true;
    }

    // 4. Academic Resources: Anyone can read, only Admins can write (updates allowed for downloads count)
    match /resources/{document} {
      allow read, write: if true;
    }

    // 5. Student profiles: Authenticated users can read, only the user themselves or Admins can write (IDOR protection)
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == studentId || isAdmin());
    }

    // 6. User Feedback & appeals: Authenticated students can create, only Admins can read/manage (Spam/IDOR protection)
    match /feedbacks/{document} {
      allow create: if isThaparStudent();
      allow read, write: if isAdmin();
    }
    match /appeals/{document} {
      allow create: if isThaparStudent();
      allow read, write: if isAdmin();
    }

    // 7. Pending Contributions: Authenticated students can create, only Admins can read/manage
    match /pending_contributions/{document} {
      allow create: if isThaparStudent();
      allow read, write: if isAdmin();
    }
  }
}
